# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (pooled for Neon serverless)
# https://console.neon.tech -> Project -> Connection Details -> Pooled connection
DATABASE_URL="postgresql://user:password@ep-example-pooler.us-east-1.aws.neon.tech/dbname?sslmode=require"

# Direct (unpooled) connection — required by Prisma Migrate with Neon
# Use the "Direct connection" string from Neon dashboard
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-example.us-east-1.aws.neon.tech/dbname?sslmode=require"

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32  (64 hex chars)
NEXTAUTH_SECRET="change-me-to-a-random-64-char-hex-string"

# Must match your deployment URL exactly
# Local:   http://localhost:3000
# Vercel:  https://secure-gate-one.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─── SMTP (Email) ────────────────────────────────────────────────────────────
# Gmail SMTP (use an App Password: https://myaccount.google.com/apppasswords)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="SecureGate <your-email@gmail.com>"

# Set to "false" if your SMTP server uses a self-signed cert (dev only)
# Omit or set "true" in production for secure TLS
SMTP_REJECT_UNAUTHORIZED="false"

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Optional — falls back to in-memory (lost on restart) when empty
# Create a free Redis db at https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
